{
  "rules": {

    "projects": {
      "$projectId": {

        // Read: owner or any member of the project
        ".read": "auth != null && (
          root.child('projects').child($projectId).child('meta/ownerId').val() === auth.uid ||
          root.child('projects').child($projectId).child('members').child(auth.uid).exists()
        )",

        // Write: owner, member, OR new project (no ownerId set yet — creation)
        ".write": "auth != null && (
          !root.child('projects').child($projectId).child('meta/ownerId').exists() ||
          root.child('projects').child($projectId).child('meta/ownerId').val() === auth.uid ||
          root.child('projects').child($projectId).child('members').child(auth.uid).exists()
        )",

        "members": {
          "$memberId": {
            // Owner can add/remove anyone.
            // A user can also add themselves (for invite-link acceptance).
            ".write": "auth != null && (
              !root.child('projects').child($projectId).child('meta/ownerId').exists() ||
              root.child('projects').child($projectId).child('meta/ownerId').val() === auth.uid ||
              auth.uid === $memberId
            )"
          }
        },

        "meta": {
          // Any member can update, or anyone if project is new (no ownerId yet)
          ".write": "auth != null && (
            !data.child('ownerId').exists() ||
            root.child('projects').child($projectId).child('meta/ownerId').val() === auth.uid ||
            root.child('projects').child($projectId).child('members').child(auth.uid).exists()
          )",
          // ownerId: settable on creation (doesn't exist yet), never changeable after
          "ownerId": {
            ".write": "auth != null &&
              (!data.exists() || data.val() === auth.uid) &&
              newData.val() === auth.uid"
          }
        }
      }
    },

    // Which projects each user belongs to.
    "userProjects": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$projectId": {
          ".write": "auth != null && (
            auth.uid === $uid ||
            root.child('projects').child($projectId).child('meta/ownerId').val() === auth.uid
          )"
        }
      }
    },

    // Invite tokens
    "invites": {
      "$token": {
        ".read":  "auth != null",
        ".write": "auth != null && (
          !data.exists() ||
          data.child('createdBy').val() === auth.uid
        )"
      }
    },

    // Each user's saved roster — private
    "roster": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // User profiles and FCM tokens
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // Schedule events — private per user
    "schedule": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // Rental portfolio — private per user
    "rentals": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // Server config — geminiKey is read-only, price lists are writable
    "config": {
      "geminiKey": {
        ".read":  "auth != null",
        ".write": "false"
      },
      "priceList": {
        ".read":  "auth != null",
        ".write": "auth != null"
      },
      "priceListCustom": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    }

  }
}
